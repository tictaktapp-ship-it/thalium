{
  "compilerOptions": {
    "skipLibCheck": true,
    "moduleResolution": "node",
    "declaration": true,
    "sourceMap": true,
    "lib": [
      "ES2022"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "target": "ES2022",
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "module": "CommonJS"
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/tests"
  ],
  "include": [
    "src/**/*"
  ]
}
